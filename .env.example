# Copy sang .env rồi điền. KHÔNG commit .env (đã có trong .gitignore).

# Facebook Messenger (lấy ở Meta Developers > App > Messenger)
MSGR_PAGE_TOKEN=
MSGR_VERIFY_TOKEN=doi-thanh-chuoi-bi-mat-cua-ban
MSGR_APP_SECRET=

# Não = Google Gemini API. Lấy key ở aistudio.google.com/apikey.
GEMINI_API_KEY=
# Model: lite | flash | pro (alias), hoặc điền thẳng model id đầy đủ (vd gemini-2.5-flash). Mặc định flash.
BOT_MODEL=flash

# PSID admin nhận báo handoff (khách cần chuyên gia) + báo lỗi bot. Nhiều admin ngăn bằng dấu phẩy.
BOT_ADMIN_UIDS=

# Cổng webhook chạy standalone.
PORT=7900

# Token bảo vệ trang admin/dashboard (http://localhost:7900/admin?token=...).
# Đặt chuỗi ngẫu nhiên dài. TRỐNG = trang admin tắt hẳn.
BOT_DASH_TOKEN=

# Follow-up: khách im sau khi bot trả lời (chưa chốt) -> nhắc nhẹ 1 tin. 1=bật, 0=tắt.
BOT_FOLLOWUP_ENABLED=1
BOT_FOLLOWUP_AFTER_H=4     # im bao nhiêu giờ thì nhắc (giữ dưới 24 để hợp lệ chính sách FB)
BOT_FOLLOWUP_CHECK_MIN=15  # chu kỳ quét (phút)

# Tin rơi: khách nhắn mà bot chưa trả lời (webhook trượt, hoặc lượt đó Gemini lỗi) -> bot nhắn bù.
# Đây là đường phục hồi duy nhất khi 1 lượt hỏng: lúc lỗi bot KHÔNG nhắn gì cho khách.
BOT_MISSED_AFTER_MIN=2     # chưa trả lời quá bao nhiêu phút thì coi là rơi
BOT_MISSED_CHECK_MIN=2     # chu kỳ quét (phút)
BOT_MISSED_AUTOREPLY=1     # 1=bot tự nhắn bù, 0=chỉ báo admin

# === CHỈ dùng khi deploy Docker trên VPS (bỏ qua khi chạy local) ===
# Domain webhook (DuckDNS hoặc domain riêng). Caddy tự lấy SSL cho domain này.
DOMAIN=hondastone.duckdns.org
# Image deploy (deploy.sh tự set; để trống khi chạy local).
IMAGE=

# Graph API version.
MSGR_GRAPH_VER=v21.0

# URL công khai của bot (chính domain ngrok/cloudflared đang expose webhook). Dùng để gửi ảnh.
PUBLIC_URL=

# Lark Base chứa ảnh sản phẩm. Tạo app nội bộ ở open.larksuite.com, cấp quyền
# bitable:read + drive:read, và CHIA SẺ Base cho app. BASE/TABLE đã lấy sẵn từ link.
LARK_APP_ID=
LARK_APP_SECRET=
LARK_BASE_APP_TOKEN=Uj9FbhUZWa6y5PsjsDyl0i1egsf
LARK_TABLE_ID=tbl1grmn4hpj4Pih
# Đổi nếu tên cột khác. Domain feishu.cn nếu dùng bản Trung Quốc.
LARK_PRODUCT_FIELD=Mã Sản Phẩm
LARK_IMAGE_FIELD=Ảnh
LARK_DOMAIN=https://open.larksuite.com

# Firebase Realtime DB: mirror conversations + stats lên cloud (backup/xem remote).
# Tạo project -> Realtime Database -> lấy URL; Project Settings > Service accounts >
# Generate new private key -> lưu file json, trỏ FIREBASE_CRED tới nó. Cả 2 trống = tắt.
FIREBASE_CRED=firebase-key.json
FIREBASE_DB_URL=https://your-project-default-rtdb.firebaseio.com

# Báo admin qua Lark (tùy chọn): URL custom-bot-webhook của group; bật ký thì điền secret
LARK_WEBHOOK_URL=
LARK_WEBHOOK_SECRET=
